<h1>Welcome to CSE Motors!</h1>

<%- messages() %>

<div class="hero-container">
  <img class="hero" src="/images/vehicles/delorean.jpg" alt="Delorean" />

  <section class="cta">
    <h2>DMC Delorean</h2>
    <p>3 cup holders</p>
    <p>Superman doors</p>
    <p>Fuzzy dice!</p>
    <button>Own Today</button>
  </section>
</div>

<div class="section-container">
  <section class="reviews">
    <h2>DMC Delorean Reviews</h2>
    <ul>
      <li>"So fast it's almost like traveling in time." (4/5)</li>
      <li>"Coolest ride on the road." (4/5)</li>
      <li>"I'm feeling McFly!" (5/5)</li>
      <li>"The most futuristic ride of our day." (4.5/5)</li>
      <li>"80's livin and love it!" (5/5)</li>
    </ul>
  </section>

  <section class="upgrades">
    <h2>Delorean Upgrades</h2>
    <div class="upgrade-grid">
      <figure>
        <div class="img-container">
            <img src="/images/upgrades/flux-cap.png" alt="flux" />
        </div>
        <caption>
          Flux Capacitor
        </caption>
      </figure>
      <figure>
        <div class="img-container">
            <img src="/images/upgrades/flame.jpg" alt="flux" />
        </div>
        <caption>
          Flame Decals
        </caption>
      </figure>
      <figure>
        <div class="img-container">
            <img src="/images/upgrades/bumper_sticker.jpg" alt="flux" />
        </div>   
        <caption>
          Bumber Stickers
        </caption>
      </figure>
      <figure>
        <div class="img-container">
            <img src="/images/upgrades/hub-cap.jpg" alt="flux" />
        </div>
        <caption>
          Hub Caps
        </caption>
      </figure>
    </div>
  </section>
</div>
